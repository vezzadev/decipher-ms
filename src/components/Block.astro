---
interface Props {
  n: string;
  title: string;
}

const { n, title } = Astro.props;
---

<section>
  <div class="flex items-baseline gap-5 mb-5">
    <span class="font-serif italic text-2xl md:text-3xl text-accent shrink-0">{n}.</span>
    <h2 class="font-serif text-2xl md:text-3xl font-black tracking-tighter uppercase leading-none">
      {title}
    </h2>
  </div>
  <div class="space-y-4 pl-10 md:pl-12"><slot /></div>
</section>
